# Session
SESSION_SECRET=generate-a-random-secret-here

# Database
DATABASE_URL=postgresql://cardwise:cardwise@localhost:5432/cardwise

# OAuth — Google (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=

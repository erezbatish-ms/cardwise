// Prisma schema for CardWise

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(uuid())
  email       String    @unique
  displayName String    @map("display_name")
  avatarUrl   String?   @map("avatar_url")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  accounts    Account[]
  cards       Card[]
  transactions Transaction[]
  scrapeLogs  ScrapeLog[]
  insightCache InsightCache[]
  categories  Category[]  @relation("UserCategories")

  @@map("users")
}

model Account {
  id          String  @id @default(uuid())
  userId      String  @map("user_id")
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider    String  // "google" | "microsoft" | "facebook"
  providerId  String  @map("provider_id")
  accessToken String? @map("access_token")
  refreshToken String? @map("refresh_token")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([provider, providerId])
  @@map("accounts")
}

model Card {
  id             String        @id @default(uuid())
  userId         String        @map("user_id")
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastFourDigits String        @map("last_four_digits")
  cardName       String?       @map("card_name")
  provider       String        @default("isracard")
  createdAt      DateTime      @default(now()) @map("created_at")
  transactions   Transaction[]
  scrapeHistory  ScrapeLog[]

  @@index([userId])
  @@map("cards")
}

model Transaction {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardId           String    @map("card_id")
  card             Card      @relation(fields: [cardId], references: [id])
  date             DateTime
  processedDate    DateTime? @map("processed_date")
  description      String
  originalAmount   Decimal   @map("original_amount")
  chargedAmount    Decimal   @map("charged_amount")
  currency         String    @default("ILS")
  categoryId       String?   @map("category_id")
  category         Category? @relation(fields: [categoryId], references: [id])
  categorySource   String    @default("ai") @map("category_source")
  merchant         String?
  installmentNum   Int?      @map("installment_num")
  installmentTotal Int?      @map("installment_total")
  memo             String?
  scraperTxnId     String?   @unique @map("scraper_txn_id")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([cardId, date])
  @@index([categoryId])
  @@map("transactions")
}

model Category {
  id           String        @id @default(uuid())
  name         String
  icon         String?
  color        String?
  isDefault    Boolean       @default(false) @map("is_default")
  userId       String?       @map("user_id")
  user         User?         @relation("UserCategories", fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([name, userId])
  @@map("categories")
}

model ScrapeLog {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardId       String   @map("card_id")
  card         Card     @relation(fields: [cardId], references: [id])
  status       String
  txnCount     Int      @default(0) @map("txn_count")
  startDate    DateTime @map("start_date")
  endDate      DateTime @map("end_date")
  errorMessage String?  @map("error_message")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("scrape_logs")
}

model InsightCache {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  cardScope String   @map("card_scope")
  period    String
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  @@unique([userId, type, cardScope, period])
  @@index([userId])
  @@map("insight_cache")
}
